// TechFides 2.0 + Velocity Engine — Database Schema
// Extends src/lib/gse/types.ts with autonomous AI sales engine tables

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH (NextAuth.js v5)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  /// bcrypt hash; null until the user completes account setup
  passwordHash  String?
  /// Tracks the welcome email lifecycle so the GSE UI can show "Sent X ago"
  welcomeEmailSentAt DateTime?
  passwordSetAt      DateTime?

  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  assignedLeads Lead[]     @relation("AssignedTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  CLOSER
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// One-time tokens that let a new employee set their password and enable MFA.
/// Sent inside the welcome email; expires in 72 hours; single-use.
model UserSetupToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // URL-safe, ~144 bits entropy
  email     String // captured at issue time so renames don't break setup
  expiresAt DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// CORE GSE ENTITIES (from src/lib/gse/types.ts)
// ============================================================

model Lead {
  id String @id @default(cuid())

  // Contact (denormalized for query speed)
  firstName String
  lastName  String
  email     String  @unique
  phone     String?
  title     String?
  company   String

  // Classification
  vertical Vertical
  service  ServiceType
  stage    PipelineStage @default(PROSPECT)
  source   LeadSource
  region   Region
  currency Currency      @default(USD)

  // Deal financials
  dealValue       Float @default(0)
  sowCost         Float @default(0)
  monthlyRetainer Float @default(0)
  probability     Int   @default(0)
  grossMargin     Float @default(0)

  // Dates
  expectedCloseDate DateTime?
  staleDays         Int       @default(0)
  lastActivity      DateTime  @default(now())

  // Metadata
  tags            String[]
  notes           String?  @db.Text
  referralPartner String?

  // GPS / Territory
  salesStatus SalesStatus @default(NOT_CONTACTED)
  lat         Float?
  lng         Float?
  city        String?
  state       String?
  zip         String?
  address     String?

  // Velocity Engine fields
  heatScore      Int      @default(0)
  tier           LeadTier @default(UNKNOWN)
  linkedinUrl    String?
  enrichmentJson Json?

  // Relations
  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  activities        Activity[]
  enrichments       Enrichment[]
  signals           Signal[]
  dossiers          Dossier[]
  nurtureSequences  NurtureSequence[]
  dealRooms         DealRoom[]
  surveys           SurveyResponse[]
  lookalikeJobs     LookalikeJob[]
  outreachSequences OutreachSequence[]
  emailDrafts       EmailDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([heatScore])
  @@index([assignedToId])
  @@index([vertical])
  @@index([tier])
}

enum PipelineStage {
  PROSPECT
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  LINKEDIN
  COLD_OUTREACH
  PARTNER
  EVENT
  INBOUND_CALL
}

enum ServiceType {
  SOVEREIGN_AI
  AI_READINESS_360
  TRANSFORMATION_MANAGEMENT
  AEGIS
}

enum Vertical {
  LEGAL
  MEDICAL
  AUTO
  TRADES
  PROPERTY_MANAGEMENT
  OTHER
}

enum Region {
  US
  MX
  CEMAC
}

enum Currency {
  USD
  MXN
  XAF
}

enum SalesStatus {
  NOT_CONTACTED
  CONTACTED
  PROSPECT
  APPOINTMENT_SCHEDULED
  PROPOSAL_SENT
  ACCEPTED
  CLIENT
  LOST
}

enum LeadTier {
  TIER_1 // $250K - $250M
  TIER_2 // $250M - $2B
  REJECTED
  UNKNOWN
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  type        ActivityType
  title       String
  description String       @db.Text
  automated   Boolean      @default(false)
  metadata    Json?
  createdAt   DateTime     @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

enum ActivityType {
  EMAIL_SENT
  EMAIL_RECEIVED
  EMAIL_OPENED
  EMAIL_CLICKED
  CALL
  MEETING
  NOTE
  STAGE_CHANGE
  DEAL_ROOM_CREATED
  DOCUMENT_SENT
  DOCUMENT_SIGNED
  PAYMENT_RECEIVED
  TASK_COMPLETED
  AUTO_NURTURE
  WEBSITE_VISIT
  LINKEDIN_VIEW
}

// ============================================================
// VELOCITY ENGINE — NEW TABLES
// ============================================================

model Enrichment {
  id     String @id @default(cuid())
  leadId String

  // Firmographic
  companyRevenue   String?
  companyEmployees Int?
  companyIndustry  String?
  companyTechStack String[]

  // Recent signals
  recentNews       Json?
  linkedinActivity Json?
  jobPostings      Json?

  // Source provider
  provider   String // "apollo" | "clay" | "manual"
  rawJson    Json
  enrichedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Signal {
  id        String     @id @default(cuid())
  leadId    String
  type      SignalType
  source    String // "instantly" | "postmark" | "website-pixel" | "linkedin"
  url       String?
  metadata  Json?
  createdAt DateTime   @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

enum SignalType {
  EMAIL_OPEN
  EMAIL_CLICK
  EMAIL_REPLY
  WEBSITE_VISIT
  PRICING_PAGE_VIEW
  CALCULATOR_USE
  DEAL_ROOM_VIEW
  LINKEDIN_VIEW
  CONTACT_FORM_SUBMIT
}

model Dossier {
  id              String   @id @default(cuid())
  leadId          String
  intentScore     Int
  triggerEvent    String
  painPoints      String[]
  recommendedHook String   @db.Text
  recommendedTier String?
  estimatedDeal   Float?
  snapshotJson    Json
  generatedAt     DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([intentScore])
}

model OutreachSequence {
  id           String          @id @default(cuid())
  leadId       String
  templateId   String?
  channel      OutreachChannel
  status       SequenceStatus  @default(DRAFT)
  currentStep  Int             @default(0)
  totalSteps   Int
  startedAt    DateTime?
  completedAt  DateTime?
  pausedReason String?

  steps OutreachStep[]
  lead  Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([status])
}

enum OutreachChannel {
  EMAIL
  LINKEDIN
  SMS
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  STOPPED
}

model OutreachStep {
  id                    String     @id @default(cuid())
  sequenceId            String
  order                 Int
  delayDays             Int        @default(0)
  subject               String?
  body                  String     @db.Text
  personalizationAnchor String?
  cta                   String?
  scheduledFor          DateTime?
  sentAt                DateTime?
  status                StepStatus @default(PENDING)

  sequence OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([scheduledFor])
}

enum StepStatus {
  PENDING
  SCHEDULED
  SENT
  FAILED
  SKIPPED
}

model SequenceTemplate {
  id              String          @id @default(cuid())
  name            String
  vertical        Vertical?
  channel         OutreachChannel
  promptJson      Json
  performanceJson Json? // open rate, reply rate, conversion rate
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ScoringWeights {
  id        String   @id @default(cuid())
  version   Int      @unique
  weights   Json
  active    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model LossReason {
  id          String   @id @default(cuid())
  category    String
  description String
  count       Int      @default(0)
  createdAt   DateTime @default(now())
}

model LookalikeJob {
  id           String    @id @default(cuid())
  sourceLeadId String
  status       String // "queued" | "running" | "completed" | "failed"
  resultsCount Int       @default(0)
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  sourceLead Lead @relation(fields: [sourceLeadId], references: [id], onDelete: Cascade)

  @@index([sourceLeadId])
}

// ============================================================
// EXISTING GSE — Nurture, Deal Room, Survey
// ============================================================

model NurtureSequence {
  id            String        @id @default(cuid())
  leadId        String
  name          String
  status        NurtureStatus @default(SCHEDULED)
  currentStep   Int           @default(0)
  triggerReason String
  startedAt     DateTime?

  lead  Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  steps NurtureStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

enum NurtureStatus {
  ACTIVE
  PAUSED
  COMPLETED
  SCHEDULED
}

model NurtureStep {
  id         String    @id @default(cuid())
  sequenceId String
  order      Int
  type       String // "email" | "wait" | "task" | "condition"
  subject    String?
  body       String?   @db.Text
  waitDays   Int?
  completed  Boolean   @default(false)
  sentAt     DateTime?

  sequence NurtureSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

model DealRoom {
  id         String         @id @default(cuid())
  leadId     String
  status     DealRoomStatus @default(DRAFT)
  accessCode String         @unique
  expiresAt  DateTime

  lead      Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  documents DealRoomDocument[]
  payments  DealRoomPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

enum DealRoomStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  PAID
  COMPLETED
}

model DealRoomDocument {
  id         String    @id @default(cuid())
  dealRoomId String
  name       String
  type       String // "sow" | "contract" | "technical" | "nda" | "invoice"
  status     String    @default("draft")
  url        String?
  signedAt   DateTime?

  dealRoom DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
}

model DealRoomPayment {
  id            String    @id @default(cuid())
  dealRoomId    String
  amount        Float
  currency      Currency  @default(USD)
  method        String // "stripe" | "wire" | "ach" | "check"
  status        String    @default("pending")
  invoiceNumber String
  paidAt        DateTime?

  dealRoom DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id          String    @id @default(cuid())
  leadId      String
  status      String    @default("pending")
  locale      String    @default("en")
  sentAt      DateTime  @default(now())
  completedAt DateTime?

  scores Json?
  nps    Int?

  testimonial            String? @db.Text
  improvementSuggestions String? @db.Text

  consentTestimonial Boolean @default(false)
  consentLogo        Boolean @default(false)
  consentSocial      Boolean @default(false)
  consentVideo       Boolean @default(false)
  consentCaseStudy   Boolean @default(false)

  referralName    String?
  referralEmail   String?
  referralCompany String?

  successCreditApplied    Boolean @default(false)
  socialProofPublished    Boolean @default(false)
  executiveAlertTriggered Boolean @default(false)

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ============================================================
// VELOCITY ENGINE — EMAIL OUTREACH & STRATEGY ENGINE
// ============================================================

model EmailDraft {
  id     String @id @default(cuid())
  leadId String

  // Content
  subject  String
  bodyHtml String @db.Text
  bodyText String @db.Text

  // Outlook Integration
  outlookDraftId   String?
  outlookMessageId String?

  // Status
  status       EmailDraftStatus @default(DRAFT)
  batchDate    DateTime
  sentAt       DateTime?
  errorMessage String?

  // Strategy Engine fields
  strategyAngle StrategyAngle
  sequenceStep  Int
  pivotedFrom   StrategyAngle?
  metadata      Json?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([batchDate])
  @@index([status])
  @@index([strategyAngle])
}

enum EmailDraftStatus {
  DRAFT
  SENT
  FAILED
  DELETED
}

enum StrategyAngle {
  STRATEGIC_ALIGNMENT
  COST_RECOVERY
  AEGIS_GOVERNANCE
  SUBSCRIPTION_REDUCTION
}

model OutreachConfig {
  id                 String  @id @default(cuid())
  dailyDraftLimit    Int     @default(50)
  dailyTier2Split    Int     @default(25)
  dailyTier1Split    Int     @default(25)
  heatScoreThreshold Int     @default(40)
  pivotAfterStep     Int     @default(3)
  scheduleHour       Int     @default(8)
  scheduleMinute     Int     @default(0)
  scheduleDays       String  @default("1,2,3,4,5")
  enabled            Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// SOCIAL MEDIA CONTENT MANAGEMENT
// ============================================================

model SocialPost {
  id          String       @id @default(cuid())
  title       String
  body        String       @db.Text
  category    PostCategory
  platforms   String[]
  status      PostStatus   @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?

  hashtags String[]
  imageUrl String?
  ctaUrl   String?
  ctaText  String?

  impressions Int @default(0)
  clicks      Int @default(0)
  likes       Int @default(0)
  comments    Int @default(0)
  shares      Int @default(0)

  reviewNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([category])
}

enum PostCategory {
  CLIENT_SUCCESS
  CLIENT_CHALLENGE
  TECH_INSIGHT
  COMPANY_CULTURE
  INDUSTRY_COMMENTARY
  LESSONS_LEARNED
  THOUGHT_LEADERSHIP
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

// ============================================================
// PROJECT MANAGEMENT & RESOURCE ASSIGNMENT
// ============================================================

model Project {
  id         String        @id @default(cuid())
  name       String
  clientName String
  leadId     String? // links back to the closed-won Lead
  service    ServiceType
  tier       String? // Silver, Gold, Platinum
  status     ProjectStatus @default(PLANNING)

  // Timeline
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?

  // Financials
  contractValue Float @default(0)
  billedAmount  Float @default(0)

  // Satisfaction
  clientNps      Int? // 0-10 NPS score
  clientFeedback String? @db.Text

  // Metadata
  description String? @db.Text
  notes       String? @db.Text

  assignments ProjectAssignment[]
  updates     ProjectUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([leadId])
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model ProjectAssignment {
  id          String  @id @default(cuid())
  projectId   String
  name        String // contractor/employee name
  email       String?
  role        String // "Technical Lead", "AI Engineer", "Consultant", etc.
  type        String // "FTE" or "Contractor"
  region      String? // "US", "MX", "GA"
  hourlyRate  Float?
  hoursLogged Float   @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectUpdate {
  id         String            @id @default(cuid())
  projectId  String
  authorName String
  authorRole String?
  type       ProjectUpdateType
  title      String
  body       String            @db.Text
  hoursSpent Float?
  blockers   String?           @db.Text

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

enum ProjectUpdateType {
  STATUS_UPDATE
  MILESTONE_REACHED
  BLOCKER_REPORTED
  HOURS_LOGGED
  COMPLETED
  CLIENT_FEEDBACK
  CLIENT_SIGNOFF
}

// ============================================================
// CLIENT ACCOUNT, SIGN-OFF, & SUPPORT TICKETS
// ============================================================

model ClientAccount {
  id             String              @id @default(cuid())
  companyName    String
  contactName    String
  email          String              @unique
  phone          String?
  tier           String // Silver, Gold, Platinum
  service        ServiceType
  status         ClientAccountStatus @default(ACTIVE)
  retainerAmount Float               @default(0)
  retainerStart  DateTime?
  retainerEnd    DateTime?
  leadId         String? // original lead
  projectId      String? // linked project
  notes          String?             @db.Text

  tickets SupportTicket[]

  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([email])
}

enum ClientAccountStatus {
  ACTIVE
  PAUSED // temporarily suspended (payment issue, etc.)
  DEACTIVATED // retainer ended
  CHURNED // client left permanently
}

model ClientSignoff {
  id           String   @id @default(cuid())
  projectId    String
  clientName   String
  clientEmail  String
  signedAt     DateTime @default(now())
  satisfaction Int? // 1-5 rating
  feedback     String?  @db.Text
  signature    String? // typed name as signature
  ipAddress    String?

  @@index([projectId])
}

model SupportTicket {
  id              String         @id @default(cuid())
  clientAccountId String
  subject         String
  description     String         @db.Text
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  category        String? // "technical", "billing", "feature-request", "training"

  // Assignment
  assignedTo    String? // consultant name
  assignedEmail String?

  // Resolution
  resolution String?   @db.Text
  resolvedAt DateTime?
  hoursSpent Float?

  // Satisfaction
  clientRating Int? // 1-5

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientAccountId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

// ============================================================
// HR — EMPLOYEE ONBOARDING
// ============================================================

model Employee {
  id    String  @id @default(cuid())
  name  String
  email String  @unique
  phone String?

  // Role + classification
  role   String // "Technical Sales Engineer", "AI Engineer", etc.
  type   EmployeeType
  status EmployeeStatus @default(ONBOARDING)
  tier   String? // "Top" | "Mid" | "Low" — matches existing /gse/hr UI
  region Region         @default(US)

  // Dates
  startDate DateTime?
  endDate   DateTime?

  // Compensation
  payRate  Float    @default(0) // monthly rate
  currency Currency @default(USD)

  // Performance (matches existing /gse/hr UI shape)
  utilization Int? // 0-100
  roi         Float? // ROI multiplier (e.g., 3.4x)
  nps         Float? // 0-10

  // Linkage
  userId    String? // optional NextAuth User if they log in
  managerId String?

  // On-disk integration (populated after scaffoldEmployeeFolder)
  folderPath String?

  notes String? @db.Text

  tasks     EmployeeOnboardingTask[]
  documents EmployeeDocument[]
  manager   Employee?                @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports   Employee[]               @relation("EmployeeManager")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([region])
  @@index([managerId])
}

enum EmployeeType {
  FTE
  CONTRACTOR
}

enum EmployeeStatus {
  ONBOARDING
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model EmployeeOnboardingTask {
  id         String @id @default(cuid())
  employeeId String

  order       Int          @default(0)
  title       String
  description String?      @db.Text
  category    TaskCategory
  owner       TaskOwner    @default(EMPLOYEE)
  required    Boolean      @default(true)

  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([category])
}

enum TaskCategory {
  HIRING
  ONBOARDING
  COMPLIANCE
  TRAINING
  TECH_SETUP
  COMPENSATION
}

enum TaskOwner {
  EMPLOYEE
  MANAGER
  HR
  IT
}

model EmployeeDocument {
  id         String @id @default(cuid())
  employeeId String

  type   DocumentType
  name   String
  status DocumentStatus @default(PENDING)

  url       String? // on-disk path or external link
  signedAt  DateTime?
  expiresAt DateTime?

  notes String? @db.Text

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([type])
  @@index([status])
}

enum DocumentType {
  NDA
  IP_ASSIGNMENT
  IC_AGREEMENT // contractor agreement
  OFFER_LETTER // FTE offer
  W9 // contractor tax form
  W4 // FTE tax form
  I9 // FTE employment eligibility
  DIRECT_DEPOSIT
  BACKGROUND_CHECK
  OTHER
}

enum DocumentStatus {
  PENDING
  SENT
  SIGNED
  RECEIVED
  EXPIRED
  MISSING
}

// ============================================================
// FORECAST — Revenue projection runs
// ============================================================

model ForecastRun {
  id          String         @id @default(cuid())
  period      ForecastPeriod
  periodStart DateTime // Start of the period this forecast covers (e.g., 2026-01-01 for YEARLY 2026)
  periodEnd   DateTime // End of the period (inclusive)

  // Headline numbers
  annualTarget     Int // Goal for the period in dollars
  ytdClosed        Int // Closed-Won YTD in dollars
  projectedRevenue Int // Win-rate-adjusted projection from active pipeline + recurring
  actualRevenue    Int @default(0) // Filled at period close
  gapToTarget      Int // annualTarget - projectedRevenue (positive = behind)

  // Stage-by-stage breakdown stored as JSON for transparency
  // Shape: { PROSPECT: {count: N, value: $X, weighted: $Y}, QUALIFIED: {...}, ... }
  breakdown Json

  // MRR snapshot (recurring revenue from ClientAccount)
  mrr Int @default(0)
  arr Int @default(0)

  // Confidence scoring — how accurate have past forecasts been?
  // 0–100. 100 = recent forecasts perfectly matched actuals.
  confidence Int @default(50)

  status     ForecastStatus @default(PUBLISHED)
  computedAt DateTime       @default(now())
  computedBy String? // "cron" | "manual:userId" | "api"
  notes      String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([period, periodStart])
  @@index([status, computedAt])
}

enum ForecastPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ForecastStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
