# ============================================================
# TechFides 2.0 + Velocity Engine — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.

# ---- Database ----
DATABASE_URL="postgresql://techfides:techfides_dev_password@localhost:5432/techfides"

# ---- Redis (BullMQ + cache) ----
REDIS_URL="redis://localhost:6379"

# ---- NextAuth.js ----
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email magic link provider (for production, use Postmark, SendGrid, or Resend)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@techfides.com"

# ---- Velocity Engine: vLLM (Local LLM) ----
VLLM_BASE_URL="http://localhost:8000/v1"
VLLM_API_KEY="replace-with-vllm-api-key"
VLLM_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# In dev, set to true to use mock responses (no GPU required)
VLLM_MOCK_MODE="true"

# ---- Velocity Engine: Apollo.io Enrichment ----
APOLLO_API_KEY=""
APOLLO_MOCK_MODE="true"

# ---- Velocity Engine: Outreach (Instantly.ai) ----
INSTANTLY_API_KEY=""
INSTANTLY_MOCK_MODE="true"

# ---- Velocity Engine: API Auth ----
# Used by external scrapers/services to authenticate with /api/v1/*
VELOCITY_API_KEY="replace-with-strong-random-token"

# ---- Observability ----
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
