# ============================================================
# TechFides 2.0 + Velocity Engine — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.

# ---- Database ----
DATABASE_URL="postgresql://techfides:techfides_dev_password@localhost:5432/techfides"

# ---- Redis (BullMQ + cache) ----
REDIS_URL="redis://localhost:6379"

# ---- NextAuth.js ----
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email magic link provider (for production, use Postmark, SendGrid, or Resend)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@techfides.com"

# ---- Velocity Engine: vLLM (Local LLM) ----
VLLM_BASE_URL="http://localhost:8000/v1"
VLLM_API_KEY="replace-with-vllm-api-key"
VLLM_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# In dev, set to true to use mock responses (no GPU required)
VLLM_MOCK_MODE="true"

# ---- Velocity Engine: Apollo.io Enrichment ----
APOLLO_API_KEY=""
APOLLO_MOCK_MODE="true"

# ---- Velocity Engine: Outreach (Instantly.ai) ----
INSTANTLY_API_KEY=""
INSTANTLY_MOCK_MODE="true"

# ---- Velocity Engine: API Auth ----
# Used by external scrapers/services to authenticate with /api/v1/*
VELOCITY_API_KEY="replace-with-strong-random-token"

# ---- Microsoft Graph (Outlook 365 Integration) ----
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""

# ---- Public URL (for email logo) ----
TECHFIDES_PUBLIC_URL="https://techfides.com"

# ---- Observability ----
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---- Stripe (TechFides account — separate from any other Stripe accounts you own) ----
# Test keys (sk_test_..., pk_test_...) are fine for development.
# Switch to live keys (sk_live_..., pk_live_...) once the TechFides Stripe
# account is activated and you're ready to take real money.
#
# Setup:
#   1. dashboard.stripe.com → top-left account switcher → New account → TechFides LLC
#   2. Developers → API keys → copy both keys below
#   3. Developers → Webhooks → Add endpoint → URL: https://<your-domain>/api/v1/stripe/webhook
#      Events to subscribe: payment_intent.succeeded, payment_intent.payment_failed, charge.refunded
#      Copy the signing secret to STRIPE_WEBHOOK_SECRET
#   4. For local dev: install Stripe CLI, run `stripe listen --forward-to localhost:3001/api/v1/stripe/webhook`
#      The CLI prints a `whsec_...` to use as STRIPE_WEBHOOK_SECRET locally.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---- App URL (used for Stripe return URL + deal-room links) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- TechFides Operations Folder ----
# Where the on-disk client/employee folders live.
# Default: ~/Desktop/TechFides on the host running this server.
TECHFIDES_OPS_ROOT="/Users/jacquesmjean/Desktop/TechFides"

# ---- Resend (transactional email) ----
# Sign up at resend.com (free tier: 3,000/mo, 100/day).
# Verify the techfides.com domain in their dashboard (3 DNS records).
# See /Operations/Resend-Setup.md for full setup.
RESEND_API_KEY=""
EMAIL_FROM_TX="TechFides <noreply@techfides.com>"
EMAIL_FROM_PERSONAL="Jacques M. Jean <jacques.jean@techfides.com>"
EMAIL_REPLY_TO="engage@techfides.com"
